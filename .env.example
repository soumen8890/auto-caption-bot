# ── Copy this file to .env and fill in your values ──────────────

# Telegram — from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token — from @BotFather
BOT_TOKEN=1234567890:ABCDEFabcdef

# MongoDB Atlas — mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/imdb_bot
DB_NAME=imdb_bot

# OMDB API — free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=abcdef12

# TMDB API — optional, higher-res posters; https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Comma-separated channel/group IDs for auto-caption (optional)
# Example: -1001234567890,-1009876543210
AUTO_CAPTION_CHANNELS=

# Caption template: default | minimal | full
CAPTION_TEMPLATE=default

# Comma-separated Telegram user IDs of admins
ADMIN_IDS=123456789

# Web server port (Render/Koyeb inject this automatically)
PORT=8080
